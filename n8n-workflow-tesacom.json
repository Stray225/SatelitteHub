{
  "name": "Tesacom - Sync Clientes IBIS",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "tesacom-clientes",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-001",
      "name": "Webhook Clientes",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [180, 300],
      "webhookId": "tesacom-clientes-webhook"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://ibistesacom.satcomhost.com/identity/connect/token",
        "sendBody": true,
        "contentType": "form-urlencoded",
        "bodyParameters": {
          "parameters": [
            { "name": "grant_type",    "value": "client_credentials" },
            { "name": "client_id",     "value": "REEMPLAZAR_CLIENT_ID" },
            { "name": "client_secret", "value": "REEMPLAZAR_CLIENT_SECRET" },
            { "name": "scope",         "value": "ibisApi" }
          ]
        },
        "options": {
          "continueOnFail": true
        }
      },
      "id": "ibis-token-002",
      "name": "Obtener Token IBIS",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [400, 300]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.access_token }}",
              "operation": "isNotEmpty"
            }
          ]
        }
      },
      "id": "check-token-008",
      "name": "Token OK?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [600, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://ibistesacom.satcomhost.com/api/v1/CustomerDetails",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $('Obtener Token IBIS').item.json.access_token }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "jsonBody": "={{ JSON.stringify({ CustomerName: $('Webhook Clientes').item.json.body.CustomerName, ParentCustomerID: $('Webhook Clientes').item.json.body.ParentCustomerID, TaxCode: $('Webhook Clientes').item.json.body.TaxCode, Description: $('Webhook Clientes').item.json.body.Description, Industry: $('Webhook Clientes').item.json.body.Industry, EmailGeneral: $('Webhook Clientes').item.json.body.EmailGeneral, MainContactPhone: $('Webhook Clientes').item.json.body.MainContactPhone, AccountManagerCode: $('Webhook Clientes').item.json.body.AccountManagerCode, Location: $('Webhook Clientes').item.json.body.Location, ShowCdrsOnInvoice: false, MainAddressSameAsParentMainAddress: false, BillingAddressSameAsMainAddress: false }) }}",
        "options": {
          "continueOnFail": true
        }
      },
      "id": "ibis-create-003",
      "name": "Crear Cliente en IBIS",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [820, 180]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ String($json.CustomerID) }}",
              "operation": "isNotEmpty"
            }
          ]
        }
      },
      "id": "check-ibis-009",
      "name": "IBIS OK?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [1020, 180]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ ok: true, message: 'Cliente creado correctamente en IBIS', CustomerID: $('Crear Cliente en IBIS').item.json.CustomerID, ibis: $('Crear Cliente en IBIS').item.json }) }}",
        "options": {
          "responseCode": 200
        }
      },
      "id": "respuesta-ok-006",
      "name": "Respuesta OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [1240, 100]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ ok: false, error: 'Error al crear cliente en IBIS', detail: ($json.Message || $json.error_description || $json.error || 'Sin detalle') }) }}",
        "options": {
          "responseCode": 500
        }
      },
      "id": "respuesta-error-007",
      "name": "Respuesta Error",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [1240, 400]
    }
  ],
  "connections": {
    "Webhook Clientes": {
      "main": [[{ "node": "Obtener Token IBIS", "type": "main", "index": 0 }]]
    },
    "Obtener Token IBIS": {
      "main": [[{ "node": "Token OK?", "type": "main", "index": 0 }]]
    },
    "Token OK?": {
      "main": [
        [{ "node": "Crear Cliente en IBIS", "type": "main", "index": 0 }],
        [{ "node": "Respuesta Error", "type": "main", "index": 0 }]
      ]
    },
    "Crear Cliente en IBIS": {
      "main": [[{ "node": "IBIS OK?", "type": "main", "index": 0 }]]
    },
    "IBIS OK?": {
      "main": [
        [{ "node": "Respuesta OK", "type": "main", "index": 0 }],
        [{ "node": "Respuesta Error", "type": "main", "index": 0 }]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "saveManualExecutions": true,
    "callerPolicy": "workflowsFromSameOwner",
    "errorWorkflow": ""
  },
  "staticData": null,
  "tags": [{ "name": "Tesacom" }]
}
