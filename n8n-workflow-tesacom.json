    {
      "parameters": {
        "method": "POST",
        "url": "https://ibistesacom.satcomhost.com/identity/connect/token",
        "sendBody": true,
        "contentType": "form-urlencoded",
        "bodyParameters": {
          "parameters": [
            { "name": "grant_type",    "value": "client_credentials" },
            { "name": "client_id",     "value": "={{ $json._cid }}" },
            { "name": "client_secret", "value": "={{ $json._csec }}" },
            { "name": "scope",         "value": "ibisApi" }
          ]
        },
        "options": {
          "continueOnFail": true,
          "timeout": 15000
        }
      },
      "id": "ibis-token-002",
      "name": "Obtener Token IBIS",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [860, 300]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.access_token }}",
              "operation": "isNotEmpty"
            }
          ]
        }
      },
      "id": "check-token-008",
      "name": "Token OK?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [1060, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://ibistesacom.satcomhost.com/api/v1/CustomerDetails",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $('Obtener Token IBIS').item.json.access_token }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { CustomerName: $('Webhook Clientes').item.json.body.CustomerName, ParentCustomerID: $('Webhook Clientes').item.json.body.ParentCustomerID, TaxCode: $('Webhook Clientes').item.json.body.TaxCode, Description: $('Webhook Clientes').item.json.body.Description, Industry: $('Webhook Clientes').item.json.body.Industry, EmailGeneral: $('Webhook Clientes').item.json.body.EmailGeneral, MainContactPhone: $('Webhook Clientes').item.json.body.MainContactPhone, AccountManagerCode: $('Webhook Clientes').item.json.body.AccountManagerCode, Location: $('Webhook Clientes').item.json.body.Location, CurrencyCode: 'USD', CreditTermsCode: 'Net 30', InvoiceDeliveryMode: 'Email', ShowCdrsOnInvoice: false, ShowZeroChargesOnInvoice: false, ShowPreviousBalanceOnInvoice: false, DeviceIdentifierOnInvoice: false, RollupInvoiceToParentCustomer: false, MainAddressSameAsParentMainAddress: false, BillingAddressSameAsMainAddress: false } }}",
        "options": {
          "continueOnFail": true
        }
      },
      "id": "ibis-create-003",
      "name": "Crear Cliente en IBIS",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1280, 180]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ String($json.CustomerID) }}",
              "operation": "isNotEmpty"
            }
          ]
        }
      },
      "id": "check-ibis-009",
      "name": "IBIS OK?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [1480, 180]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ ok: true, message: 'Cliente creado correctamente en IBIS', CustomerID: $('Crear Cliente en IBIS').item.json.CustomerID, ibis: $('Crear Cliente en IBIS').item.json }) }}",
        "options": {
          "responseCode": 200
        }
      },
      "id": "respuesta-ok-006",
      "name": "Respuesta OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [1700, 80]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ ok: false, error: 'Error al crear cliente en IBIS', detail: ($json.Message || $json.error_description || $json.error || 'Sin detalle') }) }}",
        "options": {
          "responseCode": 500
        }
      },
      "id": "respuesta-error-007",
      "name": "Respuesta Error",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [1700, 460]
    }
