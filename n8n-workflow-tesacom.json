{
  "name": "Tesacom - Sync Clientes ODOO + IBIS",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "tesacom-clientes",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "a1b2c3d4-0001-0001-0001-000000000001",
      "name": "Webhook Clientes",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "tesacom-clientes-001"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://ibistesacom.satcomhost.com/identity/connect/token",
        "sendBody": true,
        "contentType": "form-urlencoded",
        "bodyParameters": {
          "parameters": [
            { "name": "grant_type",    "value": "client_credentials" },
            { "name": "client_id",     "value": "REEMPLAZAR_CLIENT_ID" },
            { "name": "client_secret", "value": "REEMPLAZAR_CLIENT_SECRET" },
            { "name": "scope",         "value": "ibisApi" }
          ]
        },
        "options": {}
      },
      "id": "a1b2c3d4-0002-0002-0002-000000000002",
      "name": "Obtener Token IBIS",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [480, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://ibistesacom.satcomhost.com/api/v1/CustomerDetails",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $('Obtener Token IBIS').item.json.access_token }}"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "body": "={{ JSON.stringify({ Name: $('Webhook Clientes').item.json.body.nombre, TaxID: $('Webhook Clientes').item.json.body.numDoc, Email: $('Webhook Clientes').item.json.body.email, Phone: $('Webhook Clientes').item.json.body.telefono }) }}",
        "options": {}
      },
      "id": "a1b2c3d4-0003-0003-0003-000000000003",
      "name": "Crear Cliente en IBIS",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [720, 160]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://www.tesacom.net/odoo/api/res.partner",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer REEMPLAZAR_API_KEY_ODOO"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "body": "={{ JSON.stringify({ name: $('Webhook Clientes').item.json.body.nombre, vat: $('Webhook Clientes').item.json.body.numDoc, email: $('Webhook Clientes').item.json.body.email, is_company: true }) }}",
        "options": {}
      },
      "id": "a1b2c3d4-0004-0004-0004-000000000004",
      "name": "Crear Cliente en ODOO",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [720, 440]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ ok: true, ibis: $('Crear Cliente en IBIS').item.json, odoo: $('Crear Cliente en ODOO').item.json }) }}",
        "options": {}
      },
      "id": "a1b2c3d4-0005-0005-0005-000000000005",
      "name": "Respuesta OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [960, 300]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={ \"ok\": false, \"error\": \"Error al sincronizar\" }",
        "options": {
          "responseCode": 500
        }
      },
      "id": "a1b2c3d4-0006-0006-0006-000000000006",
      "name": "Respuesta Error",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [960, 500]
    }
  ],
  "connections": {
    "Webhook Clientes": {
      "main": [
        [
          { "node": "Obtener Token IBIS", "type": "main", "index": 0 }
        ]
      ]
    },
    "Obtener Token IBIS": {
      "main": [
        [
          { "node": "Crear Cliente en IBIS", "type": "main", "index": 0 },
          { "node": "Crear Cliente en ODOO", "type": "main", "index": 0 }
        ]
      ]
    },
    "Crear Cliente en IBIS": {
      "main": [
        [
          { "node": "Respuesta OK", "type": "main", "index": 0 }
        ]
      ]
    },
    "Crear Cliente en ODOO": {
      "main": [
        [
          { "node": "Respuesta OK", "type": "main", "index": 0 }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "saveManualExecutions": true,
    "callerPolicy": "workflowsFromSameOwner"
  },
  "staticData": null,
  "tags": []
}
