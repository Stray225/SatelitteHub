# Puerto del servidor local
PORT=3000

# URL base de n8n (cambiar si n8n está en otra máquina o puerto)
N8N_BASE_URL=http://n8n.tesacom.net:7830

# URL base de la API de IBIS
IBIS_BASE_URL=https://ibistesacom.satcomhost.com

# Credenciales OAuth2 por país — obtener desde el portal IBIS
# ParentCustomerID 3 = Argentina
IBIS_CID_AR=
IBIS_CSEC_AR=

# ParentCustomerID 4 = Chile
IBIS_CID_CL=
IBIS_CSEC_CL=

# ParentCustomerID 5 = Paraguay
IBIS_CID_PY=
IBIS_CSEC_PY=

# ParentCustomerID 6 = Perú
IBIS_CID_PE=
IBIS_CSEC_PE=
